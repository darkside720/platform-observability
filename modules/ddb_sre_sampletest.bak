module "ddb_sre_sampletest" {
  source = "git::https://gitlab.ews.int/ceng/tflivem/tf_module_ddb.git//modules/ddb?ref=v1.3.0"

  account_id  = var.account_id
  environment = var.environment
  region      = var.region
  category    = var.category
  application = var.application
  ticket      = var.ticket
  repo_url    = var.repo_url
  created_by  = var.created_by
  created_on  = var.created_on
  expiry_date = var.expiry_date

  create                   = var.ddb_sre_sampletest.create
  name                     = var.ddb_sre_sampletest.name
  hash_key                 = var.ddb_sre_sampletest.hash_key
  hash_key_type            = var.ddb_sre_sampletest.hash_key_type
  range_key                = var.ddb_sre_sampletest.range_key
  range_key_type           = var.ddb_sre_sampletest.range_key_type
  global_secondary_indexes = var.ddb_sre_sampletest.global_secondary_indexes
  stream_enabled           = var.ddb_sre_sampletest.stream_enabled
  stream_view_type         = var.ddb_sre_sampletest.stream_view_type
  ttl_enabled              = var.ddb_sre_sampletest.ttl_enabled
  ttl_attribute_name       = var.ddb_sre_sampletest.ttl_attribute_name
  read_capacity            = var.ddb_sre_sampletest.read_capacity
  write_capacity           = var.ddb_sre_sampletest.write_capacity
  billing_mode             = var.ddb_sre_sampletest.billing_mode
  
}