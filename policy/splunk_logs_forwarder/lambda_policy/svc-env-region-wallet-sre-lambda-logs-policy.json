{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": "logs:CreateLogGroup",
            "Resource": "arn:aws:logs:${region}:${account}:*",
			 "Condition": {
                "StringEqualsIfExists": {
                    "aws:sourceVpce": "${vpc_endpoint_logs}"
                }
            }
        },
        {
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": [
                "arn:aws:logs:${region}:${account}:log-group:/aws/lambda/${env}-${region_short_name}-wallet-sre-lambda-logs-to-splunk-logging:*"
            ],
			 "Condition": {
                "StringEqualsIfExists": {
                    "aws:sourceVpce": "${vpc_endpoint_logs}"
                }
            }
        }
    ]
}