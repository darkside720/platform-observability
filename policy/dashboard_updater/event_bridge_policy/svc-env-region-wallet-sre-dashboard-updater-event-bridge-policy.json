{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": "lambda:InvokeFunction",
            "Resource": "arn:aws:lambda:${region}:${account}:function:${env}-${region_short_name}-wallet-sre-dashboard-updater",
			 "Condition": {
                "StringEqualsIfExists": {
                    "aws:sourceVpce": "${vpc_endpoint_logs}"
                }
            }
        }
    ]
}